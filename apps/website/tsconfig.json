{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vite-plus/client", "react", "react-dom"],
    "jsx": "react-jsx",
    "allowArbitraryExtensions": true,
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@picodash/panel": ["../../packages/panel/src/index.ts"],
      "@picodash/panel/advanced": ["../../packages/panel/src/advanced.ts"],
      "@picodash/panel/ui": ["../../packages/panel/src/ui.ts"]
    },

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "strict": true,

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"]
}
