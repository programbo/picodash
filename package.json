  },
  "type": "module",
  "scripts": {
    "ready": "vp run @picodash/panel#build && vp check && vp run -r test && vp run -r build && bun run --filter @picodash/web test:e2e",
    "dev": "bun run --filter @picodash/web dev",
    "web": "bun run --filter @picodash/web dev",
    "picodash": "vp run @picodash/panel#dev",
    "test:e2e": "bun run --filter @picodash/web test:e2e",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@tsdown/css": "catalog:",
    "vite-plus": "catalog:"
  },
  "overrides": {
    "fast-uri": "3.1.4",
    "postcss": "catalog:",
    "sharp": "0.35.3",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=22.12.0"
  },
  "packageManager": "bun@1.3.14"
}
